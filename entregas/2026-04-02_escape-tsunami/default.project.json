  "gameplay_logic": [
    {
      "trigger": "Player touches SecretPassage_Part_JumpShop",
      "action": "TeleportService:TeleportToPlaceInstance(player, JUMPSHOP_MAP_ID)",
      "target_object": "SecretPassage_JumpShop",
      "logic_type": "Server"
    },
    {
      "trigger": "Player touches SecretPassage_Part_Base",
      "action": "TeleportService:TeleportToPlaceInstance(player, BASE_MAP_ID)",
      "target_object": "SecretPassage_Base",
      "logic_type": "Server"
    },
    {
      "trigger": "Player clicks JumpCard with cost_type=free",
      "action": "Grant jump_power, speed, brainrot_reward; mark card green; fire ProgressTracker unlock",
      "target_object": "JumpCard_James",
      "logic_type": "Server"
    },
    {
      "trigger": "Player clicks JumpCard with cost_type=money AND player.Money >= cost_value",
      "action": "Deduct money; grant jump_power, speed, rewards; mark card green",
      "target_object": "JumpCard_JJ | JumpCard_Mana",
      "logic_type": "Server"
    },
    {
      "trigger": "Player.WavesSurvivedStreak >= 10",
      "action": "Unlock JumpCard_Pdoro purchase; grant 10000 wave tokens on buy",
      "target_object": "JumpCard_Pdoro",
      "logic_type": "Server"
    },
    {
      "trigger": "Player.WaveKills >= 5",
      "action": "Unlock JumpCard_Matheus purchase; grant Galaxy Bat + 3x Glaciero Infernati on buy",
      "target_object": "JumpCard_Matheus",
      "logic_type": "Server"
    },
    {
      "trigger": "Player.BrainrotsSoldSession >= 10",
      "action": "Unlock JumpCard_Caylus purchase; grant 3x Infinity Lucky Box on buy",
      "target_object": "JumpCard_Caylus",
      "logic_type": "Server"
    },
    {
      "trigger": "Player.BrainrotsFusedSession >= 2",
      "action": "Unlock JumpCard_Athos purchase; fill base with Athos Brainrots on buy",
      "target_object": "JumpCard_Athos",
      "logic_type": "Server"
    },
    {
      "trigger": "AdminCommand :hideadmin {player}",
      "action": "Set AdminPanel_Frame.Visible = false; Set AdminPanel_ToggleButton.Visible = false",
      "target_object": "AdminPanel_Frame",
      "logic_type": "Server"
    },
    {
      "trigger": "AdminCommand :showadmin {player}",
      "action": "Set AdminPanel_Frame.Visible = true; Set AdminPanel_ToggleButton.Visible = true",
      "target_object": "AdminPanel_Frame",
      "logic_type": "Server"
    },
    {
      "trigger": "AdminCommand :setjump {player} {value}",
      "action": "player.Character.Humanoid.JumpPower = value",
      "target_object": "Humanoid",
      "logic_type": "Server"
    },
    {
      "trigger": "AdminCommand :setspeed {player} {value}",
      "action": "player.Character.Humanoid.WalkSpeed = value",
      "target_object": "Humanoid",
      "logic_type": "Server"
    },
    {
      "trigger": "AdminCommand :setmoney {player} {value}",
      "action": "PlayerDataService:SetMoney(player, value)",
      "target_object": "PlayerDataService",
      "logic_type": "Server"
    },
    {
      "trigger": "AdminCommand :givetokens {player} {value}",
      "action": "PlayerDataService:AddWaveTokens(player, value)",
      "target_object": "PlayerDataService",
      "logic_type": "Server"
    },
    {
      "trigger": "AdminCommand :giveitem {player} {itemId}",
      "action": "PlayerDataService:AddItem(player, itemId)",
      "target_object": "PlayerDataService",
      "logic_type": "Server"
    },
    {
      "trigger": "AdminCommand :givebrainrot {player} {brainrotId} {qty}",
      "action": "PlayerDataService:AddBrainrot(player, brainrotId, qty)",
      "target_object": "PlayerDataService",
      "logic_type": "Server"
    },
    {
      "trigger": "Brainrot placed on Base slot",
      "action": "Start income ticker: every 1s fire RemoteEvent('AddMoney', player, brainrot.income_per_second)",
      "target_object": "BaseIncomeService",
      "logic_type": "Server"
    },
    {
      "trigger": "Brainrot removed from Base slot",
      "action": "Stop income ticker for that slot",
      "target_object": "BaseIncomeService",
      "logic_type": "Server"
    },
    {
      "trigger": "JumpCard unlocked (any)",
      "action": "Fire RemoteEvent('ProgressUnlock', player, jump_id); ProgressTracker card turns green + checkmark",
      "target_object": "ProgressTracker_Frame",
      "logic_type": "Client"
    },
    {
      "trigger": "Wave Shield item active AND player touches WavePart",
      "action": "Cancel wave kill; play shield VFX; decrement shield durability",
      "target_object": "WaveShieldService",
      "logic_type": "Server"
    }
  ],

  "required_modifications": [
    {
      "original_feature": "AdminPanel button always visible",
      "new_requirement": "AdminPanel toggle button must be hideable via :hideadmin and :showadmin commands for off-screen admin use during recording"
    },
    {
      "original_feature": "Single map (Escape Waves For Brainmodz)",
      "new_requirement": "Add two auxiliary maps: 'Loja de pulos de youtubers' and 'Base separada', each replicating HUD from original map (HUD_Gems, HUD_Coins, HUD_JumpLevel, HUD_SpeedLevel, HUD_Money) with editable resource values"
    },
    {
      "original_feature": "No jump shop",
      "new_requirement": "Add JumpShop UI with 7 cards (James, JJ, Mana, Pdoro, Matheus, Caylus, Athos) showing icon, stats via symbols, cost. Cards unlock sequentially and turn green when purchased."
    },
    {
      "original_feature": "No progress tracker",
      "new_requirement": "Add ProgressTracker_Frame on TopRight showing all 7 jump icons. Unlocked state = green background + checkmark. No text/price shown, icons only."
    },
