{
	"name": "AthosHub",
	"tree": {
		"$className": "DataModel",
		"ReplicatedStorage": {
			"$className": "ReplicatedStorage",
			"Shared": {
				"$className": "Folder",
				"GameConfig":  { "$path": "src/shared/GameConfig.luau" },
				"RemoteNames": { "$path": "src/shared/RemoteNames.luau" }
			}
		},
		"ServerScriptService": {
			"$className": "ServerScriptService",
			"RemoteSetup": { "$path": "src/server/RemoteSetup.server.luau" },
			"Main":        { "$path": "src/server/Main.server.luau" },
			"Services": {
				"$className": "Folder",
				"FolderService":   { "$path": "src/server/Services/FolderService.luau" },
				"LightingService": { "$path": "src/server/Services/LightingService.luau" },
				"AnimationService": { "$path": "src/server/Services/AnimationService.luau" },
				"MapService":      { "$path": "src/server/Services/MapService.luau" },
				"SpawnService":    { "$path": "src/server/Services/SpawnService.luau" },
				"SoundService":    { "$path": "src/server/Services/SoundService.luau" },
				"WheelService":    { "$path": "src/server/Services/WheelService.luau" }
			}
		},
		"StarterPlayer": {
			"$className": "StarterPlayer",
			"StarterPlayerScripts": {
				"$className": "StarterPlayerScripts",
				"Main": { "$path": "src/client/Main.client.luau" },
				"Controllers": {
					"$className": "Folder",
					"CharacterController":    { "$path": "src/client/Controllers/CharacterController.luau" },
					"CinematicController":    { "$path": "src/client/Controllers/CinematicController.luau" },
					"NotificationController": { "$path": "src/client/Controllers/NotificationController.luau" }
				}
			}
		}
	}
}
